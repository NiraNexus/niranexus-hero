#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════
# NIRANEXUS PREPARE-COMMIT-MSG HOOK
# ═══════════════════════════════════════════════════════════════
# Auto-stamps the current AI model into every commit message.
# Reads .hermes/current-model (written by session-bootstrap).
# Agent cannot fake this without committing fraud.
#
# Usage: git does this automatically on commit.
# Install: cp .hermes/hooks/prepare-commit-msg .git/hooks/

MODEL_FILE=".hermes/current-model"
COMMIT_MSG_FILE="$1"

if [ -f "$MODEL_FILE" ]; then
    MODEL=$(cat "$MODEL_FILE" | head -1 | tr -d '[:space:]')
    if [ -n "$MODEL" ]; then
        # Prepend model tag if not already present
        if ! grep -q "^\[$MODEL\]" "$COMMIT_MSG_FILE" 2>/dev/null; then
            sed -i "1s/^/[$MODEL] /" "$COMMIT_MSG_FILE"
        fi
    fi
fi